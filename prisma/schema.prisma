generator client {
    provider = "prisma-client"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model ConfigGeral {
    id           String @id @default(uuid())
    priceBaskets Int

    active Boolean  @default(true)
    date   DateTime @db.Date

    @@unique([date])
}

model GC {
    id                 String               @id @default(uuid())
    name               String               @unique
    avatar             String?
    type               String
    tribo              String
    applicationsDailys ApplicationsDailys[]
    applicationsFixeds ApplicationsFixed[]

    applicationsCustoms ApplicationsCustom[]
}

model ApplicationsDailys {
    id             String   @id @default(uuid())
    gcId           String
    date           DateTime @db.Date
    type           String
    members        Int
    visitors       Int
    membersServing Int?

    gc GC @relation(fields: [gcId], references: [id], onDelete: Cascade)

    @@unique([gcId, date])
    @@index([gcId])
}

model ApplicationsFixed {
    id   String   @id @default(uuid())
    gcId String
    date DateTime @db.Date

    quantityMembers Int?

    amountCollected Int?
    vouchers        VoucherBaskets[]

    gc GC @relation(fields: [gcId], references: [id], onDelete: Cascade)

    @@unique([gcId, date])
    @@index([gcId])
}

model CustomRankConfig {
    id   String @id @default(uuid())
    name String @unique

    startDate DateTime @db.Date
    endDate   DateTime @db.Date

    metric CustomMetric

    // Multiplicador de pontos
    pointsMultiplier Float

    applicationsCustoms ApplicationsCustom[]
}

enum CustomMetric {
    QUANTITY
    PERCENTAGE
}

model ApplicationsCustom {
    id       String   @id @default(uuid())
    gcId     String
    configId String // liga ao CustomRankConfig
    date     DateTime @db.Date

    quantity Int?

    gc     GC               @relation(fields: [gcId], references: [id], onDelete: Cascade)
    config CustomRankConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

    @@index([gcId])
    @@index([configId])
}

model VoucherBaskets {
    id                  String @id @default(uuid())
    applicationsFixedId String

    voucher String
    price   Int?

    applicationsFixed ApplicationsFixed @relation(fields: [applicationsFixedId], references: [id], onDelete: Cascade)
}
